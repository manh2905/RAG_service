# ══════════════════════════════════════════════════════════════════
# RAG Education Service — Biến môi trường
# ══════════════════════════════════════════════════════════════════

# === Google Gemini API Key ===
GOOGLE_API_KEY=your-google-api-key-here

# === LlamaParse (LlamaIndex Cloud) — Free tier: 1000 trang/ngày ===
# Đăng ký tại: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=your-llama-cloud-api-key-here

# === Tên model Gemini (tuỳ chọn — có giá trị mặc định) ===
# GEMINI_LLM_MODEL=models/gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# === Qdrant Vector Database ===
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key   # Chỉ cần nếu dùng Qdrant Cloud
QDRANT_COLLECTION_NAME=education_docs

# === RAG Parameters ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.35

# === Callback — Giao tiếp nội bộ với Node.js ===
INTERNAL_SECRET=change-me-in-production
CALLBACK_TIMEOUT=30
CALLBACK_MAX_RETRIES=3

# === CORS — Danh sách origins được phép ===
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
